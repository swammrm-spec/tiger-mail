# Tiger Mail - Production Environment Variables
# ================================================
# Copy this to .env and fill in the values

# Database (Render provides this automatically)
DATABASE_URL=postgresql://user:password@host:5432/tiger_mail

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# SMTP Settings (your email server)
SMTP_HOST=smtp.emailarray.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password

# SMTP Relay (for internal routing)
SMTP_RELAY_PORT=3025

# OpenAI (optional - for AI analysis)
OPENAI_API_KEY=sk-your-openai-key

# Company Settings
COMPANY_NAME=TECHNO GROUP
COMPANY_LOGO_URL=https://d1v3calcp683kw.cloudfront.net/admins/images/m.safadi/blf.2cb3ab1130dd.png
