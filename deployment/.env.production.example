PORT=3001

# Use PostgreSQL in production.
DATABASE_URL=postgresql://postgres:change-me@127.0.0.1:5432/emailarray_outlook
DATABASE_SSL=false

# Security
JWT_SECRET=change-this-to-a-long-random-secret
SYNC_API_KEY=change-this-sync-api-key
APPROVAL_ACTION_SECRET=change-this-approval-secret

# Public application URL used in approval links and reminders
APP_BASE_URL=https://techno-grp--com.w.emailarray.com
PUBLIC_APP_URL=https://techno-grp--com.w.emailarray.com

# Runtime storage directory on the server
EMAILARRAY_DATA_DIR=/var/lib/emailarray-outlook

# Mail polling
BACKGROUND_MAIL_FETCH_MINUTES=5
APPROVAL_REMINDER_HOURS=9,13,17
APPROVAL_REMINDER_WINDOW_MINUTES=5

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Telegram approval bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_APPROVAL_DEFAULT_CHAT_ID=
# Example: {"ahmad.kamal@techno-grp.com":"123456789","manager2@techno-grp.com":"987654321"}
TELEGRAM_APPROVAL_CHAT_MAP=

# Optional debug run marker
DEBUG_RUN_ID=production
